{
  "name": "isometric-drawing",
  "version": "0.0.0",
  "description": "Isometric Drawing is a tool for creating isometric drawings by defining the isometric structure.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build --config vite.config.site.ts",
    "build:lib": "tsc -b && vite build --config vite.config.lib.ts",
    "docs": "npx typedoc src/lib.tsx --name 'Isometric Drawing Toolkit' --readme src/README.md --html dist/docs/",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/WylieYYYY/isometric-drawing.git"
  },
  "author": "WylieYYYY",
  "license": "MIT",
  "bugs": {
    "url": "https://gitlab.com/WylieYYYY/isometric-drawing/issues"
  },
  "homepage": "https://gitlab.com/WylieYYYY/isometric-drawing#readme",
  "dependencies": {
    "@zip.js/zip.js": "^2.8.8",
    "canvg": "^4.0.3",
    "immer": "^10.1.3",
    "quaternion": "^2.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hexgrid": "^2.0.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/browser-playwright": "4.0.13",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "playwright": "1.56.1",
    "sass": "^1.93.2",
    "typedoc": "^0.28.16",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "4.0.13",
    "vitest-browser-react": "^2.0.2"
  }
}
